NEXTJS_ENV=development
# GCP サービスアカウント JSON を 1 行の Base64 で設定（改行は JSON 内の \n のまま）
# PowerShell 例: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
# Cloudflare プレビュー用（NEXT_PUBLIC_* は Vercel/Cloudflare ダッシュボードでも可）
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=sekigime-858f6
